def parse_id(sample_id):
    parts = sample_id.split("_")
    region = parts[0]
    sample_folder = "_".join(parts[1:])
    return region, sample_folder


def get_sample_path(train_path, sample_id):
    region, sample_folder = parse_id(sample_id)
    return os.path.join(train_path, region, sample_folder)


from PIL import Image

def load_sequence(sample_path):
    files = sorted(os.listdir(sample_path))
    
    magnetograms = [f for f in files if "magnetogram" in f]

    imgs = []
    for f in magnetograms:
        img = Image.open(os.path.join(sample_path, f)).convert("L")
        imgs.append(img)

    return imgs  # list of 4 images

import torch
from torch.utils.data import Dataset

class SolarDataset(Dataset):
    def __init__(self, df, root, transform=None):
        self.df = df
        self.root = root
        self.transform = transform

    def __len__(self):
        return len(self.df)

    def __getitem__(self, idx):
        row = self.df.iloc[idx]
        sample_id = row.name
        target = row["peak_flux"]

        region, sample_folder = sample_id.split("_", 1)
        sample_path = os.path.join(self.root, region, sample_folder)

        files = sorted(os.listdir(sample_path))
        mags = [f for f in files if "magnetogram" in f]

        imgs = []
        for f in mags:
            img = Image.open(os.path.join(sample_path, f)).convert("L")

            if self.transform:
                img = self.transform(img)

            imgs.append(img)

        imgs = torch.stack(imgs)  # shape: [4, 1, H, W]

        return imgs, torch.tensor(target, dtype=torch.float32)
